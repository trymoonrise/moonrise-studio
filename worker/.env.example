# Copy to .env for local worker (never commit real secrets)

PORT=8787
PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Public URL of THIS worker. Injected into published sites so the live watermark
# can load /embed.js and call /public-checkout. In production set to the worker's
# Render URL, e.g. https://moonrise-studio-worker.onrender.com
WORKER_PUBLIC_URL=http://127.0.0.1:8787

SUPABASE_URL=https://erfaxgmnzdropviormpj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Publishable anon key (same as js/config.js) — required for /auth/* lockout-gated sign-in
SUPABASE_ANON_KEY=your_anon_key

# Auth lockout: 6 failed passwords → 1 hour temporary lock
AUTH_MAX_FAILURES=6
AUTH_LOCKOUT_MS=3600000
AUTH_FAILURE_WINDOW_MS=3600000

OPENROUTER_API_KEY=sk-or-v1-...
# Website generation model (OpenRouter). Override to A/B cheaper/faster models.
WEBSITE_GENERATION_MODEL=minimax/minimax-m2.7
# Output token caps (lower = cheaper + usually faster)
WEBSITE_MAX_OUTPUT_TOKENS=12000
WEBSITE_EDIT_MAX_OUTPUT_TOKENS=5500
WEBSITE_EDIT_MAX_INPUT_CHARS=120000
# Website Preset kit injected into the assemble prompt (more = fuller pages)
WEBSITE_PRESET_MAX_FILES=10
WEBSITE_PRESET_MAX_CHARS_EACH=1500
WEBSITE_PRESET_MAX_TOTAL_CHARS=14000
# Search-capable model used when Maps HTML has no phone/address
OPENROUTER_MAPS_MODEL=perplexity/sonar

# Prefer sk_test_/sk_live_, or a restricted key with at least:
#   checkout_session_write, customer_write (optional), webhook endpoints configured separately.
# Without checkout_session_write, Store → Subscribe and watermark checkout both fail.
STRIPE_SECRET_KEY=rk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook must receive: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# Optional: Dashboard Price id for watermark go-live. If unset, worker uses STRIPE_AMOUNT_CENTS.
STRIPE_PRICE_ID=
STRIPE_AMOUNT_CENTS=50000
# MVP+ $5/mo — optional Dashboard recurring Price id; otherwise price_data @ $5/mo
STRIPE_MVP_PRICE_ID=
STRIPE_MVP_AMOUNT_CENTS=500

# Credit plan Stripe Price IDs (optional — worker uses price_data if unset)
STRIPE_PLAN_STARTER_PRICE_ID=
STRIPE_PLAN_PRO_PRICE_ID=
STRIPE_PLAN_BUSINESS_PRICE_ID=

# Website generation credit cost (default 5 in credits.js)
# GENERATION_CREDIT_COST=5

# Custom credit top-ups ($1–$1000 default): 5 cents per credit = 20 credits per $1
# TOPUP_CENTS_PER_CREDIT=5
# TOPUP_MIN_DOLLARS=1
# TOPUP_MAX_DOLLARS=1000

# Monthly hosting billed with go-live checkout (default $4 = 400 cents)
# STRIPE_HOSTING_MONTHLY_CENTS=400

VERCEL_TOKEN=
VERCEL_TEAM_ID=
# Optional team slug for production URLs like my-project-myteam.vercel.app
# VERCEL_TEAM_SLUG=delexo

WATERMARK_URGENCY_HOURS=48

# Contact form email delivery (Auto mode)
RESEND_API_KEY=
RESEND_FROM=Moonrise Forms <onboarding@resend.dev>

# Website Presets gallery (component snippets for AI generation).
# Defaults to ../Website Presets next to this worker (moonrise-studio/Website Presets).
# WEBSITE_PRESETS_DIR=E:\MasterVault\Moonrise\moonrise-studio\Website Presets

# Generation speed: by default the worker picks the component kit + palette
# locally (instant) and makes ONE MiniMax assembly call. Set to 1 to restore the
# slower two-call flow where MiniMax also chooses the components.
# WEBSITE_PLAN_WITH_LLM=0
