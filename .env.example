STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_AMOUNT_CENTS=50000
VERCEL_TOKEN=
VERCEL_TEAM_ID=
PUBLIC_APP_URL=http://localhost:3000
WORKER_URL=http://localhost:8787
