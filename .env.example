# Frontend public config lives in js/config.js
# Worker secrets live in worker/.env (see worker/.env.example)

# Suggested local ports
# Static app:  http://localhost:3000
# Worker API:  http://localhost:8787

SUPABASE_URL=
SUPABASE_ANON_KEY=
