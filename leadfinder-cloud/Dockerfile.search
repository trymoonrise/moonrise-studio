# LeadFinder search API — Playwright Chromium on Render Web Service
FROM mcr.microsoft.com/playwright:v1.61.1-jammy

WORKDIR /app

ENV NODE_ENV=production
ENV HEADLESS=1
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

COPY package.json ./
RUN npm install --omit=dev

COPY src ./src
COPY seeds ./seeds

CMD ["node", "src/searchServer.js"]
